#!/usr/bin/env php
<?php

if ('cli' !== \PHP_SAPI)
{
  throw new Exception('This script must be run from the command line.');
}

function includeIfExists(string $file): bool
{
  return file_exists($file) && include $file;
}

if (
  !includeIfExists(__DIR__.'/../vendor/autoload.php') &&
  !includeIfExists(__DIR__.'/../../../autoload.php') &&
  !includeIfExists(__DIR__.'/../../vendor/autoload.php') &&
  !includeIfExists(__DIR__.'/../../../vendor/autoload.php') &&
  !includeIfExists(__DIR__ . '/../../../../autoload.php') &&
  !includeIfExists(__DIR__ . '/../../../../../../vendor/autoload.php')
) {
  fwrite(STDERR, 'Install dependencies using Composer.'.PHP_EOL);
  exit(1);
}

use Symfony\Component\Console\Application;
use Thinkliveid\Crew\Console\AddSkillCommand;
use Thinkliveid\Crew\Console\AddSubAgentCommand;
use Thinkliveid\Crew\Console\AddTeamCommand;
use Thinkliveid\Crew\Console\InitCommand;
use Thinkliveid\Crew\Console\InstallCommand;
use Thinkliveid\Crew\Console\InstallSubAgentCommand;
use Thinkliveid\Crew\Console\InstallTeamCommand;
use Thinkliveid\Crew\Console\NewSkillCommand;
use Thinkliveid\Crew\Console\NewSubAgentCommand;
use Thinkliveid\Crew\Console\NewTeamCommand;
use Thinkliveid\Crew\Console\SyncCommand;
use Thinkliveid\Crew\Console\UpdateCommand;
use Thinkliveid\Crew\Console\UpdateSubAgentCommand;
use Thinkliveid\Crew\Console\UpdateTeamCommand;
use Thinkliveid\Crew\Install\AgentsDetector;
use Thinkliveid\Crew\Install\Detection\DetectionStrategyFactory;
use Thinkliveid\Crew\Support\Config;

$config = new Config(getcwd());
$strategyFactory = new DetectionStrategyFactory();
$agentsDetector = new AgentsDetector($strategyFactory);

$application = new Application("AI Crew (personal skills assistant)", "1.0.0");
$application->addCommand(new InitCommand());
$application->addCommand(new SyncCommand());
$application->addCommand(new InstallCommand($config, $agentsDetector));
$application->addCommand(new AddSkillCommand($config, $agentsDetector));
$application->addCommand(new UpdateCommand($config));
$application->addCommand(new InstallSubAgentCommand($config, $agentsDetector));
$application->addCommand(new AddSubAgentCommand($config, $agentsDetector));
$application->addCommand(new UpdateSubAgentCommand($config));
$application->addCommand(new InstallTeamCommand($config, $agentsDetector));
$application->addCommand(new AddTeamCommand($config, $agentsDetector));
$application->addCommand(new UpdateTeamCommand($config));
$application->addCommand(new NewSkillCommand());
$application->addCommand(new NewSubAgentCommand());
$application->addCommand(new NewTeamCommand());

$application->run();